; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="DungeonCrawler2d"
run/main_scene="res://ui/lobby.tscn"
config/features=PackedStringArray("4.4", "Mobile")
config/icon="res://icon.png"

[autoload]

OrientationLock="*res://autoload/orientation_lock.gd"
GlobalEventBus="*res://core/events/global_event_bus.gd"
RuneManager="*res://core/systems/rune_manager.gd"
CurrencyManager="*res://core/systems/currency_manager.gd"
PlayerProfile="*res://core/meta/player_profile.gd"

[dotnet]

project/assembly_name="DungeonCrawler2d"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/handheld/orientation=1
window/stretch/mode="viewport"
window/stretch/aspect="keep"

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
