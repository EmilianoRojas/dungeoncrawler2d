; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="DungeonCrawler2d"
run/main_scene="res://ui/main_menu.tscn"
config/features=PackedStringArray("4.4", "Mobile")
config/icon="res://icon.png"
boot_splash/image="res://data/assets/splash.png"
boot_splash/bg_color=Color(0.58, 0.47, 0.35, 1)
boot_splash/fullsize=true
boot_splash/use_filter=false

[autoload]

OrientationLock="*res://autoload/orientation_lock.gd"
GlobalEventBus="*res://core/events/global_event_bus.gd"
RuneManager="*res://core/systems/rune_manager.gd"
CurrencyManager="*res://core/systems/currency_manager.gd"
PlayerProfile="*res://core/meta/player_profile.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/handheld/orientation=1
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[dotnet]

project/assembly_name="DungeonCrawler2d"

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true

[gui]

theme/custom_font="res://data/assets/fonts/PressStart2P.ttf"
theme/custom_font_size=8
